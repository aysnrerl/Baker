@model List<BakerWebUI.Dtos.Services.ResultServiceDto>
@{
    ViewData["Title"] = "ServiceList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Hizmet Listesi</h4>
            <a asp-action="CreateService" class="btn btn-primary mb-3">Yeni Hizmet Ekle</a>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Başlık</th>
                            <th>Açıklama</th>
                            <th>İkon</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.ServiceId</td>
                                    <td>@item.Title</td>
                                    <td>@item.Description</td>
                                    <td><i class="fa @item.Icon"></i> @item.Icon</td>
                                    <td>
                                        <a asp-action="DeleteService" asp-route-id="@item.ServiceId" class="btn btn-danger btn-sm">Sil</a>
                                        <a asp-action="UpdateService" asp-route-id="@item.ServiceId" class="btn btn-warning btn-sm">Güncelle</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
