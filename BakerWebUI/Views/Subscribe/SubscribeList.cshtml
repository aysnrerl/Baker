@model List<BakerWebUI.Dtos.Subscribe.ResultSubscribeDto>
@{
    ViewData["Title"] = "SubscribeList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Aboneler</h4>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>E-posta</th>
                            <th>Durum</th>
                            <th>Kayıt Tarihi</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.SubscribeId</td>
                                    <td>@item.Email</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge badge-success">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary">Pasif</span>
                                        }
                                    </td>
                                    <td>@item.CreatedDate.ToString("dd.MM.yyyy")</td>
                                    <td>
                                        <a asp-action="DeleteSubscribe" asp-route-id="@item.SubscribeId" class="btn btn-danger btn-sm">Sil</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

