@model List<BakerWebUI.Dtos.Messages.ResultMessageDto>
@{
    ViewData["Title"] = "MessageList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Mesajlar</h4>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Ad</th>
                            <th>E-posta</th>
                            <th>Konu</th>
                            <th>Tarih</th>
                            <th>Durum</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.MessageId</td>
                                    <td>@item.Name</td>
                                    <td>@item.Email</td>
                                    <td>@item.Subject</td>
                                    <td>@item.SendDate.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        @if (item.IsRead)
                                        {
                                            <span class="badge badge-success">Okundu</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning">Okunmadı</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="MessageDetail" asp-route-id="@item.MessageId" class="btn btn-info btn-sm">Detay</a>
                                        <a asp-action="DeleteMessage" asp-route-id="@item.MessageId" class="btn btn-danger btn-sm">Sil</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

