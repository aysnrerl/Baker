@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

@* Baker Temasının CSS ve Meta Etiketleri *@
@await Component.InvokeAsync("_DefaultHeadComponentPartial")

<style>
    .admin-float-btn {
        position: fixed;
        bottom: 90px; /* Yukarı çık butonunun üzerine gelmemesi için */
        right: 30px;
        z-index: 99;
        transition: 0.3s;
    }

        .admin-float-btn:hover {
            transform: scale(1.1);
        }
</style>

@* DÜZELTİLDİ: /Admin/Dashboard/Index yerine doğrudan /Dashboard/Index yapıldı *@
<a asp-controller="Dashboard" asp-action="Index" class="btn btn-dark btn-lg-square rounded-circle admin-float-btn shadow-lg">
    <i class="fa fa-lock text-primary"></i>
</a>

<body>
    @* Baker Temasının Turuncu/Siyah Navbar'ı *@
    @await Component.InvokeAsync("_DefaultNavBarComponentPartial")

    @* Sayfaların (Anasayfa, Hakkımızda vb.) içeriği tam buraya gelecek *@
    @RenderBody()

    @* Baker Temasının Footer ve Alt Bilgileri *@
    @await Component.InvokeAsync("_DefaultFooterComponentPartial")

    @* Baker Temasının JavaScript Dosyaları *@
    @await Component.InvokeAsync("_DefaultScriptComponentPartial")
</body>
</html>