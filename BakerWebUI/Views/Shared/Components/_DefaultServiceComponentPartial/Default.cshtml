@model List<BakerWebUI.Dtos.Services.ResultServiceDto>

<div class="container-xxl py-6">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.1s">
                <h1 class="display-6 mb-4">Sizin İçin Neler Sunuyoruz?</h1>
                <p class="mb-5">Baker olarak, taze ve doğal ürünlerimizle sofranıza lezzet katıyoruz.</p>
                
                <div class="row g-4">
                    @if (Model != null)
                    {
                        @foreach (var item in Model)
                        {
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="flex-shrink-0 btn-square bg-primary rounded-circle me-3">
                                        <i class="fa @item.Icon text-white"></i>
                                    </div>
                                    <h5 class="mb-0">@item.Title</h5>
                                </div>
                                <span>@item.Description</span>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.5s">
                <div class="h-100">
                    <div class="row img-twice g-3 position-relative">
                        <div class="position-absolute start-0 top-0 w-75 h-100 bg-primary rounded"
                             style="margin-left: -30px; margin-top: 30px; z-index: -1;">
                        </div>
                        
                        <div class="col-6">
                            <img class="img-fluid rounded" src="/baker-1.0.0/img/service-1.jpg" alt="">
                        </div>
                        <div class="col-6 align-self-end">
                            <img class="img-fluid rounded" src="/baker-1.0.0/img/service-2.jpg" alt="">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>