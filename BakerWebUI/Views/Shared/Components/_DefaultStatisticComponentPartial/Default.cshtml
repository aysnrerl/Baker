﻿
<div class="container-xxl py-6">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-3 col-md-6 wow fadeIn" data-wow-delay="0.1s">
                <div class="fact-item bg-light rounded text-center h-100 p-5">
                    <i class="fa fa-certificate fa-4x text-primary mb-4"></i>
                    <p class="mb-2">Ürün Çeşidi</p>
                    <h1 class="display-5 mb-0" data-toggle="counter-up">@ViewBag.productCount</h1>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 wow fadeIn" data-wow-delay="0.3s">
                <div class="fact-item bg-light rounded text-center h-100 p-5">
                    <i class="fa fa-users fa-4x text-primary mb-4"></i>
                    <p class="mb-2">Usta Şeflerimiz</p>
                    <h1 class="display-5 mb-0" data-toggle="counter-up">@ViewBag.chefCount</h1>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 wow fadeIn" data-wow-delay="0.5s">
                <div class="fact-item bg-light rounded text-center h-100 p-5">
                    <i class="fa fa-heart fa-4x text-primary mb-4"></i>
                    <p class="mb-2">Mutlu Müşteri</p>
                    <h1 class="display-5 mb-0" data-toggle="counter-up">20000</h1>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 wow fadeIn" data-wow-delay="0.7s">
                <div class="fact-item bg-light rounded text-center h-100 p-5">
                    <i class="fa fa-star fa-4x text-primary mb-4"></i>
                    <p class="mb-2">Yıllık Deneyim</p>
                    <h1 class="display-5 mb-0" data-toggle="counter-up">30</h1>
                </div>
            </div>
        </div>
    </div>
</div>