@model BakerWebUI.Dtos.Categories.CreateCategoryDto
@{
    ViewData["Title"] = "Yeni Kategori";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Yeni Kategori Ekle</h4>
            <form asp-action="CreateCategory" asp-controller="Category" method="post">
                <div class="form-group">
                    <label>Kategori Adı</label>
                    <input type="text" class="form-control" asp-for="Name" placeholder="Kategori Adı">
                </div>
                <div class="form-group">
                    <label>Açıklama</label>
                    <textarea class="form-control" asp-for="Description" rows="3" placeholder="Kategoriye dair kısa bir açıklama..."></textarea>
                </div>
                
                <button type="submit" class="btn btn-primary mr-2">Kaydet</button>
                <a asp-action="CategoryList" class="btn btn-light">İptal</a>
            </form>
        </div>
    </div>
</div>