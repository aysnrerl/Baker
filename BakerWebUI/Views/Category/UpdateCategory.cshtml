@model BakerWebUI.Dtos.Categories.UpdateCategoryDto
@{
    ViewData["Title"] = "UpdateCategory";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Kategori Güncelle</h4>
            <form asp-action="UpdateCategory" asp-controller="Category" method="post">
                <input type="hidden" asp-for="CategoryId" />
                <div class="form-group">
                    <label>Kategori Adı</label>
                    <input type="text" class="form-control" asp-for="Name" placeholder="Kategori Adı">
                </div>
                <div class="form-group">
                    <label>Açıklama</label>
                    <textarea class="form-control" asp-for="Description" rows="3" placeholder="Açıklama"></textarea>
                </div>
                <button type="submit" class="btn btn-primary mr-2">Güncelle</button>
                <a asp-action="CategoryList" class="btn btn-light">İptal</a>
            </form>
        </div>
    </div>
</div>
