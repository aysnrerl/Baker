@model List<BakerWebUI.Dtos.Products.ProductWithCategoryDto>
@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="content-wrapper">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Ürün Listesi</h4>
            <p>
                <a asp-action="CreateProduct" asp-controller="Product" class="btn btn-primary">Yeni Ürün Ekle</a>
            </p>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Ürün İsmi</th>
                        <th>Fiyat</th>
                        <th>Kategorisi</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ProductId</td>
                            <td>@item.Name</td>
                            <td>@item.Price.ToString("C2")</td>
                            <td><label class="badge badge-info">@item.CategoryName</label></td>
                            <td>
                                <a asp-action="UpdateProduct" asp-route-id="@item.ProductId" class="btn btn-success btn-sm">Güncelle</a>
                                <a asp-action="DeleteProduct" asp-route-id="@item.ProductId" class="btn btn-danger btn-sm" onclick="return confirm('Silinsin mi?')">Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>