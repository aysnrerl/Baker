@model List<BakerWebUI.Dtos.Chefs.ResultChefDto>
@{
    ViewData["Title"] = "ChefList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Şef Listesi</h4>
            <a asp-action="CreateChef" asp-controller="Chef" class="btn btn-primary mb-3">Yeni Şef Ekle</a>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Ad</th>
                            <th>Unvan</th>
                            <th>Gorsel</th>
                            <th>Islemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.chefId</td>
                                    <td>@item.name</td>
                                    <td>@item.title</td>
                                    <td><img src="@item.imageUrl" width="60" alt="@item.name" /></td>
                                    <td>
                                        <a asp-action="UpdateChef" asp-controller="Chef" asp-route-id="@item.chefId" class="btn btn-warning btn-sm">Duzenle</a>
                                        <a asp-action="DeleteChef" asp-controller="Chef" asp-route-id="@item.chefId" class="btn btn-danger btn-sm" onclick="return confirm('Silmek istediginize emin misiniz?')">Sil</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
