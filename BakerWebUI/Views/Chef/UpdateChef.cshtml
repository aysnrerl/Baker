@model BakerWebUI.Dtos.Chefs.UpdateChefDto
@{
    ViewData["Title"] = "UpdateChef";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container">
    <br />
    <br />
    <form method="post">
        <input type="hidden" asp-for="chefId" />
        <label>Kişinin Adı Soyadı</label>
        <input type="text" asp-for="name" class=" form-control" />
        <br />
        <label>Kişinin Görevi</label>
        <input type="text" asp-for="title" class=" form-control" />
        <br />
        <label>Kişinin Resmi</label>
        <input type="text" asp-for="imageUrl" class=" form-control" />
        <br />
        <button type="submit" class="btn btn-primary">Kişiyi Güncelle</button>
    </form>

</div>
