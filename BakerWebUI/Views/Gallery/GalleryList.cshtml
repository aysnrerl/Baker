@model List<BakerWebUI.Dtos.Galleries.ResultGalleryDto>
@{
    ViewData["Title"] = "GalleryList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Galeri Listesi</h4>
            <a asp-action="CreateGallery" class="btn btn-primary mb-3">Yeni Galeri Öğesi Ekle</a>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Başlık</th>
                            <th>Görsel URL</th>
                            <th>Önizleme</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.GalleryId</td>
                                    <td>@item.Title</td>
                                    <td>@item.ImageUrl</td>
                                    <td>
                                        <img src="@item.ImageUrl" alt="@item.Title" class="img-thumbnail shadow-sm" style="width: 70px; height: 50px; object-fit: cover; border-radius: 6px;" />
                                    </td>
                                    <td>
                                        <a asp-action="DeleteGallery" asp-route-id="@item.GalleryId" class="btn btn-danger btn-sm">Sil</a>
                                        <a asp-action="UpdateGallery" asp-route-id="@item.GalleryId" class="btn btn-warning btn-sm">Güncelle</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>