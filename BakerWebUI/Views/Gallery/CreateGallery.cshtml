@model BakerWebUI.Dtos.Galleries.CreateGalleryDto
@{
    ViewData["Title"] = "CreateGallery";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Yeni Galeri Öğesi Ekle</h4>
            <form asp-action="CreateGallery" asp-controller="Gallery" method="post">
                <div class="form-group">
                    <label>Başlık</label>
                    <input type="text" class="form-control" asp-for="Title" placeholder="Başlık">
                </div>
                <div class="form-group">
                    <label>Görsel URL</label>
                    <input type="text" class="form-control" asp-for="ImageUrl" placeholder="Görsel URL">
                </div>
                <button type="submit" class="btn btn-primary mr-2">Kaydet</button>
                <a asp-action="GalleryList" class="btn btn-light">İptal</a>
            </form>
        </div>
    </div>
</div>

