@model BakerWebUI.Dtos.Abouts.UpdateAboutDto
@{
    ViewData["Title"] = "UpdateAbout";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Hakkımızda Güncelle</h4>
            <form asp-action="UpdateAbout" asp-controller="About" method="post">
                <input type="hidden" asp-for="AboutId" />
                <input type="hidden" asp-for="Name" value="Hakkımızda" />
                <div class="form-group">
                    <label>Başlık</label>
                    <input type="text" class="form-control" asp-for="Title" placeholder="Başlık">
                </div>
                <div class="form-group">
                    <label>Açıklama</label>
                    <textarea class="form-control" asp-for="Description" rows="4" placeholder="Açıklama"></textarea>
                </div>
                <div class="form-group">
                    <label>Görsel URL 1</label>
                    <input type="text" class="form-control" asp-for="ImageUrl1" placeholder="Görsel URL 1">
                </div>
                <div class="form-group">
                    <label>Görsel URL 2</label>
                    <input type="text" class="form-control" asp-for="ImageUrl2" placeholder="Görsel URL 2">
                </div>
                <button type="submit" class="btn btn-primary mr-2">Güncelle</button>
                <a asp-action="AboutList" class="btn btn-light">İptal</a>
            </form>
        </div>
    </div>
</div>
    
