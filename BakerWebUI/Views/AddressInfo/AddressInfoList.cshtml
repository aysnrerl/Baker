@model List<BakerWebUI.Dtos.AddressInfos.ResultAddressInfoDto>
@{
    ViewData["Title"] = "AddressInfoList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Adres Bilgileri Listesi</h4>
            <a asp-action="CreateAddressInfo" asp-controller="AddressInfo" class="btn btn-primary mb-3">Yeni Ekle</a>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Adres</th>
                            <th>Telefon</th>
                            <th>E-posta</th>
                            <th>Çalışma Saatleri</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.AddressInfoId</td>
                                    <td>@item.Address</td>
                                    <td>@item.Phone</td>
                                    <td>@item.Email</td>
                                    <td>@item.OpenHours</td>
                                    <td>
                                        <a asp-action="UpdateAddressInfo" asp-controller="AddressInfo" asp-route-id="@item.AddressInfoId" class="btn btn-warning btn-sm">Düzenle</a>
                                        <a asp-action="DeleteAddressInfo" asp-controller="AddressInfo" asp-route-id="@item.AddressInfoId" class="btn btn-danger btn-sm" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
