@model BakerWebUI.Dtos.AddressInfos.UpdateAddressInfoDto
@{
    ViewData["Title"] = "UpdateAddressInfo";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Adres Bilgisi Güncelle</h4>
            <form asp-action="UpdateAddressInfo" asp-controller="AddressInfo" method="post">
                <input type="hidden" asp-for="AddressInfoId" />
                <div class="form-group">
                    <label>Adres</label>
                    <textarea class="form-control" asp-for="Address" rows="3" placeholder="Adres"></textarea>
                </div>
                <div class="form-group">
                    <label>Telefon</label>
                    <input type="text" class="form-control" asp-for="Phone" placeholder="Telefon">
                </div>
                <div class="form-group">
                    <label>E-posta</label>
                    <input type="email" class="form-control" asp-for="Email" placeholder="E-posta">
                </div>
                <div class="form-group">
                    <label>Çalışma Saatleri</label>
                    <input type="text" class="form-control" asp-for="OpenHours" placeholder="Çalışma Saatleri">
                </div>
                <div class="form-group">
                    <label>Harita URL</label>
                    <input type="text" class="form-control" asp-for="MapUrl" placeholder="Harita URL">
                </div>
                <button type="submit" class="btn btn-primary mr-2">Güncelle</button>
                <a asp-action="AddressInfoList" class="btn btn-light">İptal</a>
            </form>
        </div>
    </div>
</div>
